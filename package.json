{
  "name": "@bdzscaler/n8n-nodes-aiguard",
  "version": "1.0.0",
  "description": "n8n community node for Zscaler AI Guard (AI Runtime Security) API integration",
  "keywords": [
    "n8n-community-node-package",
    "zscaler",
    "aiguard",
    "ai-security",
    "ai-guard",
    "security-scanning",
    "ai-runtime-security",
    "guardrails",
    "zero-trust"
  ],
  "license": "MIT",
  "homepage": "https://github.com/zscaler/n8n-nodes-aiguard",
  "author": {
    "name": "Zscaler",
    "email": "devrel@zscaler.com"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/zscaler/n8n-nodes-aiguard.git"
  },
  "engines": {
    "node": ">=22.0.0",
    "npm": ">=10.0.0"
  },
  "packageManager": "npm@10.9.2",
  "main": "index.js",
  "scripts": {
    "build": "tsc && node -e \"const fs=require('fs');fs.mkdirSync('dist/nodes/AIGuard',{recursive:true});fs.copyFileSync('nodes/AIGuard/aiguard.svg','dist/nodes/AIGuard/aiguard.svg')\"",
    "dev": "tsc --watch",
    "format": "prettier nodes credentials --write",
    "lint": "eslint nodes credentials package.json",
    "lint:dist": "eslint -c eslint.community.config.mjs \"dist/**/*.js\"",
    "scan:local": "npm run build && npm run lint:dist",
    "scan:npm": "npx --yes @n8n/scan-community-package \"$(node -e \"const p=require('./package.json');process.stdout.write(p.name+'@'+p.version)\")\"",
    "lintfix": "eslint nodes credentials package.json --fix",
    "prepublishOnly": "npm run build && npm run lint && npm run lint:dist",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage"
  },
  "files": [
    "dist"
  ],
  "n8n": {
    "n8nNodesApiVersion": 1,
    "credentials": [
      "dist/credentials/AIGuardApi.credentials.js"
    ],
    "nodes": [
      "dist/nodes/AIGuard/AiGuard.node.js"
    ]
  },
  "dependencies": {},
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.1",
    "@n8n/eslint-plugin-community-nodes": "0.10.0",
    "@semantic-release/exec": "^7.1.0",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^12.0.6",
    "@semantic-release/npm": "^13.1.5",
    "@types/jest": "^29.5.12",
    "@types/node": "^18.19.119",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "conventional-changelog-conventionalcommits": "^9.1.0",
    "eslint": "^9.0.0",
    "eslint-plugin-n8n-nodes-base": "^1.16.6",
    "jest": "^29.7.0",
    "n8n-workflow": "^2.8.0",
    "prettier": "^3.2.5",
    "semantic-release": "^25.0.3",
    "ts-jest": "^29.1.2",
    "typescript": "^5.8.3"
  },
  "peerDependencies": {
    "n8n-workflow": "*"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "roots": [
      "<rootDir>/nodes",
      "<rootDir>/credentials"
    ],
    "testMatch": [
      "**/__tests__/**/*.ts",
      "**/?(*.)+(spec|test).ts"
    ],
    "transform": {
      "^.+\\.ts$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.ts",
      "!**/*.d.ts",
      "!**/node_modules/**",
      "!**/dist/**"
    ],
    "coverageReporters": [
      "text",
      "lcov",
      "html"
    ]
  }
}
